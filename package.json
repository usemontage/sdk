{
  "name": "@montageai/sdk",
  "version": "0.4.0",
  "description": "Montage SDK — call the Montage API from any JS/TS app and render generated HTML artifacts.",
  "license": "MIT",
  "homepage": "https://usemontage.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usemontage/sdk.git"
  },
  "keywords": [
    "montage",
    "ai",
    "llm",
    "ui",
    "html",
    "agent",
    "anthropic",
    "openai",
    "mastra",
    "langchain",
    "vercel-ai-sdk",
    "agno",
    "cloudflare-agents",
    "strands"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent-adapter": {
      "types": "./dist/agent-adapter.d.ts",
      "import": "./dist/agent-adapter.js"
    },
    "./capability-bridge": {
      "types": "./dist/capability-bridge.d.ts",
      "import": "./dist/capability-bridge.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./integrations": {
      "types": "./dist/integrations.d.ts",
      "import": "./dist/integrations.js"
    },
    "./html": {
      "types": "./dist/html/index.d.ts",
      "import": "./dist/html/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config /dev/null",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^25.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
