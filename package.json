{
  "name": "@montage/sdk",
  "version": "0.3.0",
  "description": "Montage SDK — call the Montage API from any JS/TS app and render generated HTML artifacts.",
  "license": "MIT",
  "homepage": "https://montage.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/montage-dev/montage.git",
    "directory": "packages/montage-sdk"
  },
  "keywords": [
    "montage",
    "ai",
    "llm",
    "ui",
    "html",
    "agent",
    "anthropic",
    "openai",
    "mastra",
    "langchain",
    "vercel-ai-sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent-adapter": {
      "types": "./dist/agent-adapter.d.ts",
      "import": "./dist/agent-adapter.js"
    },
    "./capability-bridge": {
      "types": "./dist/capability-bridge.d.ts",
      "import": "./dist/capability-bridge.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./mastra": {
      "types": "./dist/mastra.d.ts",
      "import": "./dist/mastra.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.ts",
      "import": "./dist/ai-sdk.js"
    },
    "./integrations": {
      "types": "./dist/integrations.d.ts",
      "import": "./dist/integrations.js"
    },
    "./html": {
      "types": "./dist/html/mount-html-block.d.ts",
      "import": "./dist/html/mount-html-block.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/agent-adapter.ts src/capability-bridge.ts src/tools.ts src/integrations.ts src/mastra.ts src/ai-sdk.ts src/html/mount-html-block.ts src/react/index.ts --format esm --dts --clean --external react --external react-dom",
    "dev": "tsup src/index.ts src/agent-adapter.ts src/capability-bridge.ts src/tools.ts src/integrations.ts src/mastra.ts src/ai-sdk.ts src/html/mount-html-block.ts src/react/index.ts --format esm --dts --watch --external react --external react-dom",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config /dev/null",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^25.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
